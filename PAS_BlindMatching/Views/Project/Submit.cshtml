@{
    ViewData["Title"] = "Submit Project";
}

<h2>Submit Project</h2>

<form method="post" asp-action="Submit" asp-controller="Project">
    @Html.AntiForgeryToken()

    <input type="text" name="title" placeholder="Project Title" required /><br />
    <textarea name="abstract" placeholder="Abstract" required></textarea><br />
    <input type="text" name="techStack" placeholder="Tech Stack" required /><br />
    <input type="text" name="researchArea" placeholder="Research Area" required /><br />
    <button type="submit">Submit</button>
</form>