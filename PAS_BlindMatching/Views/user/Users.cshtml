@model List<PAS_BlindMatching.Models.User>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-danger text-white py-3 d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="bi bi-person-gear me-2"></i>User Management</h3>
            <span class="badge bg-light text-danger">@Model.Count total users</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Research Area</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 align-middle text-muted small">@user.Id</td>
                                <td class="align-middle fw-semibold">@user.Name</td>
                                <td class="align-middle small">@user.Email</td>
                                <td class="align-middle">
                                    @{
                                        var badgeClass = user.Role switch
                                        {
                                            "Admin" => "bg-dark",
                                            "Supervisor" => "bg-success",
                                            "Group" => "bg-primary",
                                            _ => "bg-info text-dark"
                                        };
                                    }
                                    <span class="badge @badgeClass">@user.Role</span>
                                </td>
                                <td class="align-middle small text-muted">
                                    @(string.IsNullOrEmpty(user.ResearchArea) ? "—" : user.ResearchArea)
                                </td>
                                <td class="align-middle text-center">
                                    @if (user.Role != "Admin")
                                    {
                                        <form asp-action="DeleteUser" asp-controller="Admin" method="post"
                                              onsubmit="return confirm('Delete user @user.Name? This cannot be undone.')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <i class="bi bi-trash me-1"></i>Delete
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Protected</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table thead th {
        border-top: none;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        color: #6c757d;
    }

    .table tbody td {
        padding: 0.9rem 0.75rem;
    }
</style>
